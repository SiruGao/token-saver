{
  "name": "token-saver-desktop",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "Local-first desktop app for diagnosing and reducing AI-agent token waste.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "check": "npm run version:check && npm run startup:check && tsc --noEmit && npm test",
    "test": "node --import tsx --test src/**/*.test.ts",
    "version:check": "node scripts/check-version-sync.mjs",
    "startup:check": "node scripts/check-startup-safety.mjs",
    "release:version": "node scripts/set-version.mjs",
    "registry:check": "node scripts/validate-strategy-registry.mjs",
    "registry:sync": "node scripts/sync-strategy-registry.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
